# === Conexao com o Supabase ===
# Mesma URL do frontend (VITE_SUPABASE_URL)
SUPABASE_URL=https://okvufcwkophaadttmjwa.supabase.co
# Chave SECRETA (NAO a publishable/anon). Ignora RLS. NUNCA comitar este .env.
# Use a chave nova, revogavel: Project Settings -> API Keys -> Secret keys (sb_secret_...).
SUPABASE_SECRET_KEY=sb_secret_coloque-a-chave-aqui
# (Compat) o service_role legado ainda funciona se voce usar SUPABASE_SERVICE_ROLE_KEY.
# Bucket de arquivos (igual ao frontend)
STORAGE_BUCKET=project-files

# === Identificacao / operacional ===
WORKER_ID=vm-linux-01
# Papeis deste worker (quais filas processa). Para rodar 2 workers na MESMA
# assinatura (custo zero) e evitar que a geracao de modelo bloqueie texto/voz/
# copiloto, rode 2 servicos systemd com WORKER_ROLES e WORKER_ID diferentes
# (definidos no proprio unit, que tem prioridade sobre este .env):
#   Worker de modelos:  WORKER_ROLES=models  WORKER_ID=vm-models
#   Worker de IA rapida: WORKER_ROLES=ai     WORKER_ID=vm-ai
# Vazio / 'all' = 1 worker unico processa todas as filas (comportamento padrao).
# WORKER_ROLES=all
# Intervalo do polling de fallback (ms)
POLL_INTERVAL_MS=15000
# Timeout de uma geracao (ms). 30 min cobre os 10-20 min tipicos.
JOB_TIMEOUT_MS=1800000
# Tentativas maximas antes de marcar o job como erro definitivo
MAX_ATTEMPTS=3
# Intervalo do heartbeat que alimenta o selo "Gerador online/offline" na tela (ms)
HEARTBEAT_INTERVAL_MS=30000

# === Espelho de chamados 0800 (Ellevo -> tabela chamados_0800 no Supabase) ===
# SQL Server interno da empresa (so alcancavel da rede interna). Sem MSSQL_HOST
# o sync fica DESLIGADO e o worker roda normalmente. Com 2 workers na mesma VM,
# configure em UM so para nao sincronizar em dobro.
# MSSQL_HOST=10.0.10.59
# MSSQL_PORT=1433
# MSSQL_DATABASE=Siplan_AcessoIA
# MSSQL_USER=HUB_Siplan
# MSSQL_PASSWORD=coloque-a-senha-aqui
# Intervalo do sync (ms). 300000 = 5 min.
# CHAMADOS_SYNC_INTERVAL_MS=300000
# Dias apos o fim do pos-implantacao em que o cliente ainda e sincronizado
# CHAMADOS_SYNC_GRACE_DAYS=60

# === Geracao headless (Claude Code + skill criar-modelo-mesclado) ===
# Binario do Claude Code. OPCIONAL: se ausente (ou obsoleto), o worker descobre
# sozinho o binario nativo MAIS NOVO da extensao do VS Code -> nao quebra quando a
# extensao atualiza. Deixe comentado para usar a auto-descoberta:
# CLAUDE_BIN=/home/administrator/.vscode-server/extensions/anthropic.claude-code-2.1.201-linux-x64/resources/native-binary/claude
# (Se a extensao nao estiver no caminho padrao ~/.vscode-server/extensions, aponte com VSCODE_EXT_DIR.)
# Projeto onde a skill roda
ORION_PROJECT_DIR=/opt/Orion.Modelos
# Pasta onde a skill salva os JSONs (padrao: <ORION_PROJECT_DIR>/modelos_criados)
# MODELOS_CRIADOS_DIR=/opt/Orion.Modelos/modelos_criados
# Pasta onde o worker baixa o doc do cliente antes de rodar a skill
ENTRADA_DIR=/home/administrator/siplan_entrada

# === Preenchimento por voz (jobs 'voice_note') ===
# Transcricao roda LOCALMENTE na VM com whisper.cpp: sem chave, custo zero, o audio
# nao sai da VM. Requer whisper.cpp compilado + um modelo ggml + ffmpeg instalado.
# Instalar (uma vez):
#   git clone https://github.com/ggerganov/whisper.cpp /opt/whisper.cpp
#   cd /opt/whisper.cpp && cmake -B build && cmake --build build -j --config Release
#   ./models/download-ggml-model.sh large-v3-turbo        # bom pt-BR, rapido (~1.5GB)
#   sudo apt-get install -y ffmpeg
# Binario do whisper.cpp (builds novos: build/bin/whisper-cli; antigos: ./main)
WHISPER_BIN=/opt/whisper.cpp/build/bin/whisper-cli
# Arquivo do modelo ggml
WHISPER_MODEL=/opt/whisper.cpp/models/ggml-large-v3-turbo.bin
# Idioma forcado (pt = portugues)
WHISPER_LANGUAGE=pt
# Binario do ffmpeg (converte o audio do navegador em WAV 16kHz mono)
FFMPEG_BIN=ffmpeg
