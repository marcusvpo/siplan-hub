# === Conexao com o Supabase ===
# Mesma URL do frontend (VITE_SUPABASE_URL)
SUPABASE_URL=https://okvufcwkophaadttmjwa.supabase.co
# Chave SECRETA (NAO a publishable/anon). Ignora RLS. NUNCA comitar este .env.
# Use a chave nova, revogavel: Project Settings -> API Keys -> Secret keys (sb_secret_...).
SUPABASE_SECRET_KEY=sb_secret_coloque-a-chave-aqui
# (Compat) o service_role legado ainda funciona se voce usar SUPABASE_SERVICE_ROLE_KEY.
# Bucket de arquivos (igual ao frontend)
STORAGE_BUCKET=project-files

# === Identificacao / operacional ===
WORKER_ID=vm-linux-01
# Intervalo do polling de fallback (ms)
POLL_INTERVAL_MS=15000
# Timeout de uma geracao (ms). 30 min cobre os 10-20 min tipicos.
JOB_TIMEOUT_MS=1800000
# Tentativas maximas antes de marcar o job como erro definitivo
MAX_ATTEMPTS=3

# === Geracao headless (Claude Code + skill criar-modelo-mesclado) ===
# Binario do Claude Code. ATENCAO: a versao muda quando a extensao do VS Code atualiza;
# reconferir com: ls ~/.vscode-server/extensions/ | grep claude
CLAUDE_BIN=/home/administrator/.vscode-server/extensions/anthropic.claude-code-2.1.201-linux-x64/resources/native-binary/claude
# Projeto onde a skill roda
ORION_PROJECT_DIR=/opt/Orion.Modelos
# Pasta onde a skill salva os JSONs (padrao: <ORION_PROJECT_DIR>/modelos_criados)
# MODELOS_CRIADOS_DIR=/opt/Orion.Modelos/modelos_criados
# Pasta onde o worker baixa o doc do cliente antes de rodar a skill
ENTRADA_DIR=/home/administrator/siplan_entrada
